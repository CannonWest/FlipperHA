# Home Assistant base URL as seen by the bridge computer.
HA_BASE_URL=http://homeassistant.local:8123

# Create this in Home Assistant under Profile -> Long-lived access tokens.
HA_TOKEN=replace-with-your-home-assistant-token

# Shared secret between the Flipper app and this bridge.
# Use a long random value and copy the same value to bridge.cfg on the Flipper SD card.
FLIPPERHA_BRIDGE_KEY=replace-with-a-long-random-shared-key
